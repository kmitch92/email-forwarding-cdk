# Dependencies
node_modules

# Compiled JavaScript output (in bin/ and lib/ only — keep test/*.js excluded too)
bin/*.js
lib/**/*.js
test/**/*.js
*.d.ts

# CDK
cdk.out
.cdk.staging

# TypeScript
*.tsbuildinfo

# Environment
.env

# Coverage
coverage/

# Local config (contains domain + forwarding email — gitignored because repo is public)
local.config.json

# CDK context cache (autogenerated by context-provider lookups like HostedZone.fromLookup;
# contains the user's business domain. Safe to ignore — regenerated on next `cdk synth` with AWS creds.)
cdk.context.json
